# ============================================
# 依赖与构建产物
# ============================================
node_modules/
dist/
.vite/

# ============================================
# 锁文件（仅保留 npm，其余包管理器忽略）
# ============================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# 环境变量（包含敏感信息，禁止提交）
# ============================================
.env
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.staging
.env.staging.local

# ============================================
# 日志文件
# ============================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
selenium-debug.log
**/*.log

# ============================================
# 测试覆盖率
# ============================================
tests/**/coverage/
tests/e2e/reports
coverage/
*.lcov

# ============================================
# 编辑器与 IDE
# ============================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.local
*.swp
*.swo
*~

# ============================================
# 操作系统生成文件
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================
# 调试与临时文件
# ============================================
*.tgz
*.tar.gz
/tmp/
/temp/

# ============================================
# TypeScript（如果后续引入）
# ============================================
*.tsbuildinfo
